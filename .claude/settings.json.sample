{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "AWS_BEARER_TOKEN_BEDROCK": "xxxx-yyyy-zzzz-0123",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "model": "global.anthropic.claude-opus-4-6-v1[1m]",
  "permissions": {
    "allow": [
      "Bash(* --version)",
      "Bash(* --help *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./config.json)",
      "Read(./config.toml)",
      "Read(./config.xml)",
      "Read(./config.yaml)",
      "Read(./config.yml)",
      "Read(./secrets/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
