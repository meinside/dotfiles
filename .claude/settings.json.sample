{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./config.*)",
      "Read(./secrets/**)"
    ]
  },
  "env": {
    "AWS_BEARER_TOKEN_BEDROCK": "xxxx-yyyy-zzzz-0123",
    "CLAUDE_CODE_USE_BEDROCK": "1",

    "ENABLE_LSP_TOOL": "1"
  }
}
