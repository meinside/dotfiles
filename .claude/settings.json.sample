{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "Co-Authored-By: Claude Code <noreply@anthropic.com>",
    "pr": "\n\n🤖 Generated with [Claude Code](https://claude.ai/code)"
  },
  "env": {
    "AWS_BEARER_TOKEN_BEDROCK": "xxxx-yyyy-zzzz-0123",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "model": "global.anthropic.claude-opus-4-6-v1[1m]",
  "permissions": {
    "allow": [
      "Bash(* --version)",
      "Bash(* --help *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./config.json)",
      "Read(./config.toml)",
      "Read(./config.xml)",
      "Read(./config.yaml)",
      "Read(./config.yml)",
      "Read(./secrets/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "*.amazonaws.com",
        "index.crates.io",
        "static.crates.io",
        "*.github.com",
        "*.githubusercontent.com",
        "proxy.golang.org",
        "sum.golang.org",
        "*.googleapis.com",
        "luarocks.org",
        "registry.npmjs.org"
      ]
    }
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
