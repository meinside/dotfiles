#!/usr/bin/env bash
#
# ~/.claude/hooks/notify.sh.sample
#
# (Sample)
#
# Notification hook for Claude Code.
# Sends alerts to the user when Claude needs attention.
#
# Supported notification types:
#   - permission_prompt: permission dialog appeared
#   - idle_prompt: Claude has been idle, waiting for user
#   - elicitation_dialog: MCP server requests user input
#
# Input JSON fields (via stdin):
#   - session_id: current session ID
#   - transcript_path: path to session transcript
#   - cwd: current working directory
#   - hook_event_name: "Notification"
#   - message: notification text content
#   - title: optional notification title
#   - notification_type: one of the supported types above
#
# last update: 2026.03.25.

set -euo pipefail

# Read JSON input from stdin
input=$(cat)

# Parse common fields
session_id=$(echo "$input" | jq -r '.session_id // empty')
cwd=$(echo "$input" | jq -r '.cwd // empty')
notification_type=$(echo "$input" | jq -r '.notification_type // empty')
message=$(echo "$input" | jq -r '.message // empty')

# Project name from cwd
project=""
if [ -n "$cwd" ]; then
    project=$(basename "$cwd")
    [ "$cwd" = "$HOME" ] && project="~"
fi

# Fallback message if not provided
if [ -z "$message" ]; then
    message="[$notification_type] Notification from Claude Code"
fi

########################################
# Notification dispatch
########################################
# Uncomment/add desired notification methods below.

send_notification() {
    local title="$1"
    local subtitle="$2"
    local message="$3"
    local type="$4"

