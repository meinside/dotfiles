    #         >/dev/null 2>&1
    # fi

    # --- System sound (macOS) ---
    # afplay /System/Library/Sounds/Glass.aiff &>/dev/null &

    # --- Log to file ---
    # echo "$(date '+%Y-%m-%d %H:%M:%S') [$type] $title ($subtitle): $message" \
    #     >> ~/.claude/hooks/notify.log
}

send_notification "Claude Code" "$project" "$message" "$notification_type"

exit 0
