    # fi

    # --- System sound (macOS) ---
    # afplay /System/Library/Sounds/Glass.aiff &

    # --- Log to file ---
    # echo "$(date '+%Y-%m-%d %H:%M:%S') [$type] $title: $message" \
    #     >> ~/.claude/hooks/notify.log

    : # no-op placeholder
}

########################################
# Route by notification type
########################################
case "$notification_type" in
permission_prompt)
    send_notification "$title" "$message" "permission_prompt"
    ;;
idle_prompt)
    send_notification "$title" "$message" "idle_prompt"
    ;;
elicitation_dialog)
    send_notification "$title" "$message" "elicitation_dialog"
    ;;
*)
    # Unknown type - still notify
    send_notification "$title" "$message" "$notification_type"
    ;;
esac

exit 0
