{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "Co-Authored-By: Claude Code <noreply@anthropic.com>",
    "pr": "\n\n🤖 Generated with [Claude Code](https://claude.ai/code)"
  },
  "env": {
    "AWS_BEARER_TOKEN_BEDROCK": "xxxx-yyyy-zzzz-0123",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/notify.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/notify.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "model": "global.anthropic.claude-opus-4-6-v1[1m]",
  "permissions": {
    "allow": [
      "Bash(* --help *)",
      "Bash(* --version)",
      "Bash(basename *)",
      "Bash(cargo *)",
      "Bash(cat *)",
      "Bash(cmake *)",
      "Bash(date *)",
      "Bash(dirname *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git status)",
      "Bash(git branch *)",
      "Bash(git stash list)",
      "Bash(git remote -v)",
      "Bash(git tag *)",
      "Bash(go *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(make *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pwd)",
      "Bash(realpath *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(uname *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)"
    ],
    "deny": [
      "Bash(chmod 777 *)",
      "Bash(curl * | bash *)",
      "Bash(curl * | sh *)",
      "Bash(git checkout -- *)",
      "Bash(git clean -f *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(rm -fr *)",
      "Bash(rm -rf *)",
      "Bash(wget * | bash *)",
      "Bash(wget * | sh *)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/.gnupg/**)",
      "Edit(**/.ssh/**)",
      "Edit(**/*.key)",
      "Edit(**/*.p12)",
      "Edit(**/*.pem)",
      "Edit(**/*.pfx)",
      "Edit(**/*credentials*)",
      "Edit(**/*secret*)",
      "Edit(**/config.json)",
      "Edit(**/config.toml)",
      "Edit(**/config.xml)",
      "Edit(**/config.yaml)",
      "Edit(**/config.yml)",
      "Edit(**/secrets/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.gnupg/**)",
      "Read(**/.ssh/**)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pem)",
      "Read(**/*.pfx)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",
      "Read(**/config.json)",
      "Read(**/config.toml)",
      "Read(**/config.xml)",
      "Read(**/config.yaml)",
      "Read(**/config.yml)",
      "Read(**/secrets/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "*.amazonaws.com",
        "index.crates.io",
        "static.crates.io",
        "*.github.com",
        "*.githubusercontent.com",
        "proxy.golang.org",
        "sum.golang.org",
        "*.googleapis.com",
        "luarocks.org",
        "registry.npmjs.org"
      ]
    }
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/claude/statusline.sh"
  }
}
